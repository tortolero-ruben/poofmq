#!/bin/bash
#
# Pre-commit hook to run frontend and Go checks before commits
# Prevents committing code that would fail CI
#
# Install: cp scripts/git-hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# Or run: make setup-hooks
#

set -euo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

FRONTEND_TMP_BACKUP=""

restore_generated_frontend_dirs() {
    if [ -z "${FRONTEND_TMP_BACKUP}" ] || [ ! -d "${FRONTEND_TMP_BACKUP}" ]; then
        return
    fi

    for dir in actions routes wayfinder; do
        if [ -d "${FRONTEND_TMP_BACKUP}/${dir}" ]; then
            mv "${FRONTEND_TMP_BACKUP}/${dir}" "resources/js/${dir}"
        fi
    done

    rmdir "${FRONTEND_TMP_BACKUP}"
}

echo -e "${YELLOW}Running pre-commit checks...${NC}"

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

GO_FILES=$(echo "${STAGED_FILES}" | grep '\.go$' || true)

FRONTEND_FILES=$(echo "${STAGED_FILES}" | grep -E \
'^(resources/.*\.(css|js|jsx|json|scss|ts|tsx)|eslint\.config\.js|package(-lock)?\.json|tsconfig\.json|vite\.config\.ts|\.prettierrc|\.prettierignore)$' || true)

if [ -n "${FRONTEND_FILES}" ]; then
    if ! command -v npm &> /dev/null; then
        echo -e "${RED}❌ npm is required to run frontend pre-commit checks.${NC}"
        exit 1
    fi

    # Wayfinder outputs are ignored in git and not present in CI jobs.
    # Hide them so local lint behavior matches CI.
    FRONTEND_TMP_BACKUP=$(mktemp -d /tmp/poofmq-precommit-frontend-XXXXXX)
    trap restore_generated_frontend_dirs EXIT

    for dir in resources/js/actions resources/js/routes resources/js/wayfinder; do
        if [ -d "${dir}" ] && git check-ignore -q "${dir}"; then
            mv "${dir}" "${FRONTEND_TMP_BACKUP}/$(basename "${dir}")"
        fi
    done

    echo -e "${YELLOW}Running frontend format checks...${NC}"
    if ! npm run format:check; then
        echo -e "${RED}❌ Frontend formatting checks failed. Fix formatting before committing.${NC}"
        exit 1
    fi
    echo -e "${GREEN}✓ Frontend formatting checks passed${NC}"

    echo -e "${YELLOW}Running frontend lint checks...${NC}"
    if ! npm run lint:check; then
        echo -e "${RED}❌ Frontend lint checks failed. Fix lint issues before committing.${NC}"
        exit 1
    fi
    echo -e "${GREEN}✓ Frontend lint checks passed${NC}"
else
    echo -e "${GREEN}No frontend files changed, skipping frontend checks${NC}"
fi

if [ -z "$GO_FILES" ]; then
    echo -e "${GREEN}No Go files changed, skipping Go checks${NC}"
    echo -e "${GREEN}✅ All pre-commit checks passed${NC}"
    exit 0
fi

# Check if services/go-api directory exists
if [ ! -d "services/go-api" ]; then
    echo -e "${GREEN}No services/go-api directory, skipping Go checks${NC}"
    exit 0
fi

cd services/go-api

# Check if go is available
if ! command -v go &> /dev/null; then
    echo -e "${YELLOW}⚠ go not found, skipping Go checks${NC}"
    exit 0
fi

# Run go vet
echo -e "${YELLOW}Running go vet...${NC}"
if ! go vet ./...; then
    echo -e "${RED}❌ go vet failed. Fix the issues before committing.${NC}"
    exit 1
fi
echo -e "${GREEN}✓ go vet passed${NC}"

# Run go test (only on changed packages for speed)
echo -e "${YELLOW}Running go tests...${NC}"
if ! go test ./... -short; then
    echo -e "${RED}❌ go test failed. Fix the issues before committing.${NC}"
    exit 1
fi
echo -e "${GREEN}✓ go tests passed${NC}"

# Run gofmt check
echo -e "${YELLOW}Checking gofmt...${NC}"
UNFORMATTED=$(gofmt -l .)
if [ -n "$UNFORMATTED" ]; then
    echo -e "${RED}❌ The following files are not formatted:${NC}"
    echo "$UNFORMATTED"
    echo -e "${YELLOW}Run: cd services/go-api && gofmt -w ${UNFORMATTED}${NC}"
    exit 1
fi
echo -e "${GREEN}✓ gofmt passed${NC}"

echo -e "${GREEN}✅ All pre-commit checks passed${NC}"
exit 0

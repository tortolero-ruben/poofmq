APP_NAME=poofmq-portal
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
PORTAL_HTTP_PORT=8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=poofmq
DB_USERNAME=poofmq
DB_PASSWORD=poofmq
POSTGRES_HOST_PORT=5432

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_HOST_PORT=6379
REDIS_QUEUE=poofmq:default

GO_API_BASE_URL=http://localhost:8080
GO_API_TIMEOUT_SECONDS=5
GO_API_HTTP_PORT=8080
GO_API_HOST_PORT=8080
GO_API_LOG_LEVEL=debug
GO_API_ALLOW_ORIGIN=http://localhost:8000

MAIL_MAILER=resend
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@poofmq.com"
MAIL_FROM_NAME="${APP_NAME}"
RESEND_API_KEY=
FORTIFY_EMAIL_VERIFICATION=true

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
# Turnstile (Cloudflare) — required for "Start instantly" queue creation. Get keys at https://dash.cloudflare.com/?to=/:account/turnstile
CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=
DONATION_WEBHOOK_SECRET=

RAILWAY_ENVIRONMENT_NAME=local
RAILWAY_WORKSPACE_ID=
RAILWAY_PROJECT_ID=
RAILWAY_API_TOKEN=
RAILWAY_GRAPHQL_ENDPOINT=https://backboard.railway.com/graphql/v2
RAILWAY_API_TIMEOUT_SECONDS=10

POOFMQ_MONTHLY_BUDGET_CENTS=500
POOFMQ_ADMIN_EMAILS=rubentortolero@gmail.com
POOFMQ_BASE_GLOBAL_LIMIT_PER_MINUTE=60
POOFMQ_ACTIVE_MONTH_BOOST_ENABLED=false
POOFMQ_ACTIVE_MONTH_BOOST_MULTIPLIER=2
POOFMQ_OBS_ERROR_RATE_PERCENT=2
POOFMQ_OBS_PUSH_LATENCY_MS=75
POOFMQ_OBS_POP_LATENCY_MS=75
POOFMQ_OBS_REDIS_MEMORY_BYTES=8000000
POOFMQ_OBS_BURN_RATE_CENTS_PER_DAY=20
POOFMQ_OBS_RAILWAY_SNAPSHOT_MAX_AGE_MINUTES=120

VITE_APP_NAME="${APP_NAME}"
